#!/usr/bin/env python3
"""
HeadHunter vacancy helper for the OpenClaw sandbox.

Primary use case:
- public vacancy search without OAuth for openclaw skill execution

Optional use case:
- manual OAuth login to get authenticated search behaviour and /me checks
"""

from __future__ import annotations

import argparse
import json
import os
import secrets
import sys
import textwrap
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, Iterable, List, Optional, Tuple
from urllib.error import HTTPError, URLError
from urllib.parse import parse_qs, urlencode, urlparse
from urllib.request import Request, urlopen

API_BASE = "https://api.hh.ru"
OAUTH_AUTHORIZE_URL = "https://hh.ru/oauth/authorize"
OAUTH_TOKEN_URL = f"{API_BASE}/token"
DEFAULT_REDIRECT_URI = "http://127.0.0.1:8765/callback"
DEFAULT_TOKEN_FILE = os.path.expanduser("~/.config/hh_api/token.json")
DEFAULT_USER_AGENT = "openclaw-sandbox-hh/1.0 (set HH_USER_AGENT)"
TIMEOUT = 30


class HHError(RuntimeError):
    """Domain-specific exception."""


@dataclass
class Config:
    client_id: Optional[str]
    client_secret: Optional[str]
    redirect_uri: str
    token_file: Path
    user_agent: str


class TokenStore:
    def __init__(self, path: Path) -> None:
        self.path = path

    def save(self, token: Dict[str, Any]) -> None:
        self.path.parent.mkdir(parents=True, exist_ok=True)
        payload = dict(token)
        payload.setdefault("obtained_at", utcnow_iso())
        self.path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding="utf-8")

    def load(self) -> Dict[str, Any]:
        if not self.path.exists():
            raise HHError(
                f"Токен не найден: {self.path}. Выполните login-user, login-app или set-token."
            )
        return json.loads(self.path.read_text(encoding="utf-8"))

    def exists(self) -> bool:
        return self.path.exists()


class HHClient:
    def __init__(self, config: Config) -> None:
        self.config = config
        self.store = TokenStore(config.token_file)

    def build_authorize_url(self, state: str) -> str:
        self._require_oauth_config()
        params = {
            "response_type": "code",
            "client_id": self.config.client_id,
            "redirect_uri": self.config.redirect_uri,
            "state": state,
        }
        return f"{OAUTH_AUTHORIZE_URL}?{urlencode(params)}"

    def exchange_code(self, code: str) -> Dict[str, Any]:
        self._require_oauth_config()
        token = self._post_token(
            {
                "grant_type": "authorization_code",
                "client_id": self.config.client_id,
                "client_secret": self.config.client_secret,
                "code": code,
                "redirect_uri": self.config.redirect_uri,
            }
        )
        token["auth_kind"] = "user"
        return token

    def login_app(self) -> Dict[str, Any]:
        self._require_oauth_config()
        token = self._post_token(
            {
                "grant_type": "client_credentials",
                "client_id": self.config.client_id,
                "client_secret": self.config.client_secret,
            }
        )
        token["auth_kind"] = "app"
        return token

    def refresh_user_token(self, refresh_token: str) -> Dict[str, Any]:
        self._require_oauth_config()
        token = self._post_token(
            {
                "grant_type": "refresh_token",
                "client_id": self.config.client_id,
                "client_secret": self.config.client_secret,
                "refresh_token": refresh_token,
            }
        )
        token["auth_kind"] = "user"
        return token

    def search_vacancies(self, params: Dict[str, Any], auth_mode: str) -> Dict[str, Any]:
        if auth_mode == "public":
            return self._request_json("GET", f"{API_BASE}/vacancies", params=params)
        if auth_mode == "require":
            return self._authorized_request("GET", f"{API_BASE}/vacancies", params=params)
        if auth_mode == "auto" and self.store.exists():
            try:
                return self._authorized_request("GET", f"{API_BASE}/vacancies", params=params)
            except HHHTTPError as exc:
                # Applicant OAuth is valid for /me, but vacancy search may still
                # be forbidden for this token shape. Fall back to the public
                # search path so the helper remains useful after login.
                if exc.status == 403:
                    return self._request_json("GET", f"{API_BASE}/vacancies", params=params)
                raise
        return self._request_json("GET", f"{API_BASE}/vacancies", params=params)

    def me(self) -> Dict[str, Any]:
        return self._authorized_request("GET", f"{API_BASE}/me")

    def _post_token(self, form: Dict[str, str]) -> Dict[str, Any]:
        return self._request_json("POST", OAUTH_TOKEN_URL, form=form, context="получение OAuth-токена")

    def _authorized_request(self, method: str, url: str, **kwargs: Any) -> Dict[str, Any]:
        token = self.store.load()
        access_token = token.get("access_token")
        if not access_token:
            raise HHError("В token.json нет access_token.")

        headers = {"Authorization": f"Bearer {access_token}"}
        try:
            return self._request_json(method, url, headers=headers, **kwargs)
        except HHHTTPError as exc:
            error_value = extract_error_value(exc.data)
            if exc.status == 403 and error_value in {"token_expired", "bad_authorization"}:
                refreshed = self._try_reauthorize(token)
                if refreshed:
                    headers["Authorization"] = f"Bearer {refreshed['access_token']}"
                    return self._request_json(method, url, headers=headers, **kwargs)
            raise

    def _try_reauthorize(self, token: Dict[str, Any]) -> Optional[Dict[str, Any]]:
        auth_kind = token.get("auth_kind")
        if auth_kind == "user" and token.get("refresh_token"):
            new_token = self.refresh_user_token(token["refresh_token"])
            if not new_token.get("refresh_token"):
                new_token["refresh_token"] = token.get("refresh_token")
            self.store.save(new_token)
            return new_token

        if auth_kind == "app":
            new_token = self.login_app()
            self.store.save(new_token)
            return new_token

        return None

    def _request_json(
        self,
        method: str,
        url: str,
        *,
        params: Optional[Dict[str, Any]] = None,
        form: Optional[Dict[str, str]] = None,
        headers: Optional[Dict[str, str]] = None,
        context: Optional[str] = None,
    ) -> Dict[str, Any]:
        query_params = normalize_query_params(params or {})
        request_url = append_query_params(url, query_params)
        request_headers = {
            "Accept": "application/json",
            "User-Agent": self.config.user_agent,
            "HH-User-Agent": self.config.user_agent,
        }
        if headers:
            request_headers.update(headers)

        data: Optional[bytes] = None
        if form is not None:
            request_headers["Content-Type"] = "application/x-www-form-urlencoded"
            data = urlencode(form).encode("utf-8")

        request = Request(request_url, data=data, headers=request_headers, method=method)

        try:
            with urlopen(request, timeout=TIMEOUT) as response:
                payload = response.read().decode("utf-8")
                parsed = safe_json_text(payload)
                if isinstance(parsed, dict):
                    return parsed
                raise HHError(f"{context or 'запрос'}: сервер вернул неожиданный JSON")
        except HTTPError as exc:
            payload = exc.read().decode("utf-8", errors="replace")
            parsed = safe_json_text(payload)
            raise HHHTTPError(
                build_error_message(
                    status=exc.code,
                    data=parsed,
                    body=payload,
                    context=context or f"{method} {url}",
                ),
                status=exc.code,
                data=parsed,
            ) from exc
        except URLError as exc:
            raise HHError(f"{context or 'запрос'}: {exc.reason}") from exc

    def _require_oauth_config(self) -> None:
        if not self.config.client_id:
            raise HHError("Не задан client_id. Передайте HH_CLIENT_ID или --client-id.")
        if not self.config.client_secret:
            raise HHError("Не задан client_secret. Передайте HH_CLIENT_SECRET или --client-secret.")


class HHHTTPError(HHError):
    def __init__(self, message: str, *, status: int, data: Any) -> None:
        super().__init__(message)
        self.status = status
        self.data = data


def utcnow_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def safe_json_text(payload: str) -> Any:
    try:
        return json.loads(payload)
    except Exception:
        return None


def first(items: Optional[List[str]]) -> Optional[str]:
    return items[0] if items else None


def parse_manual_code_input(raw: str) -> str:
    raw = raw.strip()
    if not raw:
        raise HHError("Пустой ввод. Нужен code или полный redirect URL.")
    if raw.startswith("http://") or raw.startswith("https://"):
        parsed = urlparse(raw)
        query = parse_qs(parsed.query)
        code = first(query.get("code"))
        if not code:
            error = first(query.get("error"))
            desc = first(query.get("error_description"))
            raise HHError(f"В redirect URL нет code. error={error!r}, error_description={desc!r}")
        return code
    return raw


def extract_error_value(data: Any) -> Optional[str]:
    if isinstance(data, dict):
        if isinstance(data.get("value"), str):
            return data["value"]
        errors = data.get("errors")
        if isinstance(errors, list) and errors:
            first_item = errors[0]
            if isinstance(first_item, dict) and isinstance(first_item.get("value"), str):
                return first_item["value"]
        if isinstance(data.get("error"), str):
            return data["error"]
    return None


def build_error_message(*, status: int, data: Any, body: str, context: str) -> str:
    message = f"{context}: HTTP {status}"
    if isinstance(data, dict):
        error = data.get("error")
        desc = data.get("error_description")
        errors = data.get("errors")
        if error or desc:
            message += f"; error={error!r}; description={desc!r}"
        elif errors:
            message += f"; errors={errors!r}"
        else:
            message += f"; body={json.dumps(data, ensure_ascii=False)}"
        return message
    trimmed_body = body.strip()
    if trimmed_body:
        return f"{message}; body={trimmed_body[:1000]}"
    return message


def normalize_query_params(params: Dict[str, Any]) -> List[Tuple[str, str]]:
    normalized: List[Tuple[str, str]] = []
    for key, value in params.items():
        if value is None:
            continue
        if isinstance(value, list):
            for item in value:
                normalized.append((key, stringify_query_value(item)))
            continue
        normalized.append((key, stringify_query_value(value)))
    return normalized


def stringify_query_value(value: Any) -> str:
    if isinstance(value, bool):
        return "true" if value else "false"
    return str(value)


def append_query_params(url: str, params: Iterable[Tuple[str, str]]) -> str:
    items = list(params)
    if not items:
        return url
    return f"{url}?{urlencode(items)}"


def parse_kv(raw: str) -> Tuple[str, str]:
    if "=" not in raw:
        raise HHError(f"Параметр {raw!r} должен быть в виде key=value")
    key, value = raw.split("=", 1)
    key = key.strip()
    value = value.strip()
    if not key:
        raise HHError(f"Пустой ключ в параметре {raw!r}")
    return key, value


def require_config(args: argparse.Namespace) -> Config:
    redirect_uri = args.redirect_uri or os.getenv("HH_REDIRECT_URI") or DEFAULT_REDIRECT_URI
    token_file = Path(args.token_file or os.getenv("HH_TOKEN_FILE") or DEFAULT_TOKEN_FILE).expanduser()
    user_agent = args.user_agent or os.getenv("HH_USER_AGENT") or DEFAULT_USER_AGENT
    return Config(
        client_id=args.client_id or os.getenv("HH_CLIENT_ID"),
        client_secret=args.client_secret or os.getenv("HH_CLIENT_SECRET"),
        redirect_uri=redirect_uri,
        token_file=token_file,
        user_agent=user_agent,
    )


def add_common_auth_args(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--client-id", help="OAuth Client ID; иначе HH_CLIENT_ID")
    parser.add_argument("--client-secret", help="OAuth Client Secret; иначе HH_CLIENT_SECRET")
    parser.add_argument("--redirect-uri", help="OAuth Redirect URI; иначе HH_REDIRECT_URI")
    parser.add_argument("--token-file", help=f"Путь к token.json; иначе HH_TOKEN_FILE или {DEFAULT_TOKEN_FILE}")
    parser.add_argument("--user-agent", help="User-Agent / HH-User-Agent; иначе HH_USER_AGENT")


def command_login_user(args: argparse.Namespace) -> int:
    config = require_config(args)
    client = HHClient(config)
    state = secrets.token_urlsafe(24)
    url = client.build_authorize_url(state=state)

    print("Откройте URL в локальном браузере, авторизуйтесь и вставьте полный redirect URL или только code:\n")
    print(url)
    print()
    raw = input("redirect URL или code: ")
    token = client.exchange_code(parse_manual_code_input(raw))
    client.store.save(token)
    print(f"User token сохранён в {config.token_file}")
    return 0


def command_login_app(args: argparse.Namespace) -> int:
    config = require_config(args)
    client = HHClient(config)
    token = client.login_app()
    client.store.save(token)
    print(f"App token сохранён в {config.token_file}")
    if token.get("expires_in") is not None:
        print(f"expires_in={token['expires_in']}")
    return 0


def command_set_token(args: argparse.Namespace) -> int:
    config = require_config(args)
    token = {
        "access_token": args.access_token,
        "token_type": "bearer",
        "auth_kind": args.auth_kind,
        "obtained_at": utcnow_iso(),
    }
    if args.refresh_token:
        token["refresh_token"] = args.refresh_token
    TokenStore(config.token_file).save(token)
    print(f"Токен сохранён в {config.token_file}")
    return 0


def command_me(args: argparse.Namespace) -> int:
    config = require_config(args)
    client = HHClient(config)
    print(json.dumps(client.me(), ensure_ascii=False, indent=2))
    return 0


def command_search(args: argparse.Namespace) -> int:
    config = require_config(args)
    client = HHClient(config)
    data = client.search_vacancies(build_search_params(args), auth_mode=args.auth_mode)
    if args.format == "json":
        print(json.dumps(data, ensure_ascii=False, indent=2))
        return 0
    print_summary_table(data)
    return 0


def build_search_params(args: argparse.Namespace) -> Dict[str, Any]:
    params: Dict[str, Any] = {}

    def put(key: str, value: Any) -> None:
        if value is None:
            return
        if isinstance(value, list) and not value:
            return
        params[key] = value

    put("text", args.text)
    put("area", args.area)
    put("search_field", args.search_field)
    put("professional_role", args.professional_role)
    put("experience", args.experience)
    put("employment", args.employment)
    put("schedule", args.schedule)
    put("salary", args.salary)
    put("currency", args.currency)
    put("order_by", args.order_by)
    put("label", args.label)
    put("page", args.page)
    put("per_page", args.per_page)
    put("host", args.host)

    if args.only_with_salary:
        put("only_with_salary", True)
    if args.clusters:
        put("clusters", True)
    if args.enable_snippets:
        put("enable_snippets", True)

    for raw in args.param or []:
        key, value = parse_kv(raw)
        if key in params:
            current = params[key]
            if isinstance(current, list):
                current.append(value)
            else:
                params[key] = [current, value]
        else:
            params[key] = value

    return params


def format_salary(salary: Any) -> str:
    if not isinstance(salary, dict) or not salary:
        return "—"
    fr = salary.get("from")
    to = salary.get("to")
    currency = salary.get("currency") or ""
    gross = salary.get("gross")
    gross_text = " gross" if gross is True else " net" if gross is False else ""
    if fr is not None and to is not None:
        return f"{fr}..{to} {currency}{gross_text}".strip()
    if fr is not None:
        return f"от {fr} {currency}{gross_text}".strip()
    if to is not None:
        return f"до {to} {currency}{gross_text}".strip()
    return currency or "—"


def print_summary_table(data: Dict[str, Any]) -> None:
    found = data.get("found")
    pages = data.get("pages")
    page = data.get("page")
    per_page = data.get("per_page")
    items = data.get("items") or []

    print(f"found={found}  page={page}  pages={pages}  per_page={per_page}")
    print()

    if not items:
        print("Ничего не найдено")
        return

    for idx, item in enumerate(items, start=1):
        print(f"[{idx}] {item.get('name', '<без названия>')}")
        print(f"    id: {item.get('id') or '—'}")
        print(f"    employer: {(item.get('employer') or {}).get('name') or '—'}")
        print(f"    area: {(item.get('area') or {}).get('name') or '—'}")
        print(f"    salary: {format_salary(item.get('salary'))}")
        print(f"    published_at: {item.get('published_at') or '—'}")
        print(f"    url: {item.get('alternate_url') or item.get('url') or '—'}")
        print()


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="openclaw-hh-vacancies",
        formatter_class=argparse.RawTextHelpFormatter,
        description=textwrap.dedent(
            """
            HH vacancy helper for OpenClaw.

            Примеры:
              openclaw-hh-vacancies search --text "python developer" --per-page 5
              openclaw-hh-vacancies search --text "data engineer" --param schedule=remote --format json
              openclaw-hh-vacancies login-user
              openclaw-hh-vacancies me
            """
        ),
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    login_user = subparsers.add_parser("login-user", help="OAuth авторизация пользователя в ручном режиме")
    add_common_auth_args(login_user)
    login_user.set_defaults(func=command_login_user)

    login_app = subparsers.add_parser("login-app", help="Получить app token и сохранить его")
    add_common_auth_args(login_app)
    login_app.set_defaults(func=command_login_app)

    me = subparsers.add_parser("me", help="Проверить текущий токен через /me")
    add_common_auth_args(me)
    me.set_defaults(func=command_me)

    set_token = subparsers.add_parser("set-token", help="Сохранить уже полученный access token вручную")
    add_common_auth_args(set_token)
    set_token.add_argument("--access-token", required=True, help="Готовый access token")
    set_token.add_argument("--refresh-token", help="Refresh token, если есть")
    set_token.add_argument(
        "--auth-kind",
        choices=["app", "user", "manual"],
        default="manual",
        help="Тип токена для дальнейшей переавторизации",
    )
    set_token.set_defaults(func=command_set_token)

    search = subparsers.add_parser("search", help="Искать вакансии")
    add_common_auth_args(search)
    search.add_argument("--auth-mode", choices=["auto", "public", "require"], default="auto")
    search.add_argument("--host", default="hh.ru", help="Сайт группы HH. По умолчанию hh.ru")
    search.add_argument("--text", help="Текстовый запрос")
    search.add_argument("--area", action="append", help="area, можно повторять")
    search.add_argument("--search-field", action="append", help="search_field, можно повторять")
    search.add_argument("--professional-role", action="append", help="professional_role, можно повторять")
    search.add_argument("--experience", help="experience")
    search.add_argument("--employment", action="append", help="employment, можно повторять")
    search.add_argument("--schedule", action="append", help="schedule, можно повторять")
    search.add_argument("--salary", type=int, help="salary")
    search.add_argument("--currency", help="currency")
    search.add_argument("--label", action="append", help="label, можно повторять")
    search.add_argument("--order-by", help="order_by")
    search.add_argument("--page", type=int, default=0, help="Номер страницы")
    search.add_argument("--per-page", type=int, default=10, help="Размер страницы")
    search.add_argument("--only-with-salary", action="store_true", help="Только вакансии с зарплатой")
    search.add_argument("--clusters", action="store_true", help="Запросить clusters=true")
    search.add_argument("--enable-snippets", action="store_true", help="Запросить enable_snippets=true")
    search.add_argument(
        "--param",
        action="append",
        help="Любой дополнительный query-параметр в формате key=value; можно повторять",
    )
    search.add_argument("--format", choices=["table", "json"], default="table", help="Формат вывода")
    search.set_defaults(func=command_search)

    return parser


def main(argv: Optional[List[str]] = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        return int(args.func(args))
    except KeyboardInterrupt:
        print("Прервано пользователем", file=sys.stderr)
        return 130
    except HHError as exc:
        print(f"Ошибка: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
